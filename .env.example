# --- 基础配置 ---
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# --- AI 配置 (任选其一) ---

# 方案 A: 使用 DeepSeek (推荐，性价比极高)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_MODEL=deepseek-v4-flash
YTMETRICS_USE_ENV_PROXY=false
YTMETRICS_SOCKS_PROXY=socks5h://127.0.0.1:1180
YTMETRICS_ALLOW_SNAPSHOT_FALLBACK=false

# 方案 B: 使用 OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4-turbo

# 方案 C: 其他兼容 OpenAI 接口的厂商 (如月之暗面 Kimi, 智谱 AI 等)
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# --- 可选：百度评论情感分析 ---
# 不配置时，应用仍可运行，只是不启用评论情感分析能力。
BAIDU_APP_ID=your_baidu_app_id_here
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here
